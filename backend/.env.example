# Copy this to .env and fill in your values

# Application
APP_NAME="Digital Lending Platform"
DEBUG=true

# Database
# Local dev: SQLite (no setup required)
DATABASE_URL=sqlite:///./lending.db
# Production (Vercel): use PostgreSQL — SQLite does not persist on serverless
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT — use a long random string in production (e.g. openssl rand -hex 32)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — comma-separated list of allowed frontend origins
# Local:
ALLOWED_ORIGINS=http://localhost:3000
# Production (set this in Vercel environment variables):
# ALLOWED_ORIGINS=https://your-app.vercel.app
